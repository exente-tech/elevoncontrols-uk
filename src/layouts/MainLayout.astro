---
import "../styles/global.css";
import { market } from "../data/current-market";
import { marketKeys, markets } from "../data/markets";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const path = Astro.url.pathname;
const site = market.site;
const navigation = market.navigation;
const footer = market.footer;
const canonicalUrl = new URL(path, `${site.url}/`).toString();
const alternateMarkets = marketKeys.map((key) => ({
  lang: markets[key].lang,
  href: new URL(path, `${markets[key].site.url}/`).toString()
}));
---

<!doctype html>
<html lang={market.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    {alternateMarkets.map((item) => <link rel="alternate" hreflang={item.lang} href={item.href} />)}
    <meta property="og:title" content={`${title} | ${site.name}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={market.lang} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ${site.name}`} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} | {site.name}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-shell">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true"></span>
          <span>
            <strong>{site.brandPrimary}</strong>
            <small>{site.brandSecondary}</small>
          </span>
        </a>

        <nav class="nav">
          {navigation.map((item) => (
            <a class:list={["nav-link", path === item.href && "is-active"]} href={item.href}>
              {item.label}
            </a>
          ))}
        </nav>

        <a class="button button-primary nav-cta" href="/contact">{footer.navCtaLabel}</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <a class="brand brand-footer" href="/">
            <span class="brand-mark" aria-hidden="true"></span>
            <span>
              <strong>{site.brandPrimary}</strong>
              <small>{site.brandSecondary}</small>
            </span>
          </a>
          <p class="footer-copy">{footer.summary}</p>
        </div>

        <div>
          <h3>{footer.companyHeading}</h3>
          {navigation.slice(4).map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
          <a href="/services">{navigation[1].label}</a>
          <a href="/industries">{navigation[2].label}</a>
        </div>

        <div>
          <h3>{footer.servicesHeading}</h3>
          {footer.serviceLinks.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>

        <div>
          <h3>{footer.contactHeading}</h3>
          <a href={`mailto:${site.email}`}>{site.email}</a>
          <a href={`tel:${site.phone.replace(/[^+\d]/g, "")}`}>{site.phone}</a>
          <p>{site.address}</p>
        </div>
      </div>

      <div class="container footer-bottom">
        <p>&copy; 2026 {site.name}. {footer.copyright}</p>
      </div>
    </footer>
  </body>
</html>
