---
import MainLayout from "../layouts/MainLayout.astro";
import { market } from "../data/current-market";

const home = market.home;
const audiences = market.audiences.items;
const services = market.services.items;
const caseStudies = market.caseStudies;
---

<MainLayout title={home.title} description={home.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{home.eyebrow}</p>
        <h1>{home.headline}</h1>
        <p class="hero-copy">{home.heroCopy}</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/contact">{home.primaryCta}</a>
          <a class="button button-secondary" href="/contact">{home.secondaryCta}</a>
        </div>
      </div>

      <div class="hero-panel">
        <div class="signal-card">
          <span>{home.focusedExpertiseLabel}</span>
          <strong>{home.focusedExpertiseBody}</strong>
        </div>
        <div class="metric-grid">
          {home.metrics.map((item) => (
            <article>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="trust-bar">
    <div class="container trust-items">
      {home.trustItems.map((item) => <span>{item}</span>)}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{home.whoWeHelpEyebrow}</p>
        <h2>{home.whoWeHelpTitle}</h2>
      </div>
      <div class="card-grid card-grid-three">
        {audiences.map((audience) => (
          <a class="info-card" href={audience.href}>
            <h3>{audience.title}</h3>
            <p>{audience.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{home.servicesEyebrow}</p>
        <h2>{home.servicesTitle}</h2>
      </div>
      <div class="card-grid card-grid-two">
        {services.map((service) => (
          <a class="info-card info-card-strong" href={service.href}>
            <h3>{service.title}</h3>
            <p>{service.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section specialization">
    <div class="container split-grid">
      <div>
        <p class="eyebrow">{home.specialisationEyebrow}</p>
        <h2>{home.specialisationTitle}</h2>
        <p>{home.specialisationBody}</p>
      </div>

      <ul class="feature-list">
        {home.specialisationItems.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{home.whyEyebrow}</p>
        <h2>{home.whyTitle}</h2>
      </div>
      <div class="check-grid">
        {home.whyItems.map((item) => <div>{item}</div>)}
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{home.caseStudiesEyebrow}</p>
        <h2>{home.caseStudiesTitle}</h2>
      </div>
      <div class="card-grid card-grid-three">
        {caseStudies.slice(0, 3).map((item) => (
          <article class="info-card">
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <p class="result-copy">{item.result}</p>
          </article>
        ))}
      </div>
      <a class="text-link" href="/case-studies">{home.caseStudiesLinkLabel}</a>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container cta-shell">
      <div>
        <p class="eyebrow">{home.ctaEyebrow}</p>
        <h2>{home.ctaTitle}</h2>
        <p>{home.ctaBody}</p>
      </div>
      <div class="hero-actions">
        <a class="button button-primary" href="/contact">{home.primaryCta}</a>
        <a class="button button-secondary" href="/contact">{home.secondaryCta}</a>
      </div>
    </div>
  </section>
</MainLayout>
