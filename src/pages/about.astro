---
import MainLayout from "../layouts/MainLayout.astro";
import PageHero from "../components/PageHero.astro";
import { market } from "../data/current-market";

const about = market.about;
---

<MainLayout title={about.title} description={about.description}>
  <PageHero eyebrow={about.heroEyebrow} title={about.heroTitle} description={about.heroDescription} />

  <section class="section">
    <div class="container prose-block">
      <p>{about.intro}</p>
    </div>
  </section>

  {about.sections.map((section) => (
    <section class:list={["section", section.muted && "section-muted"]}>
      <div class="container prose-block">
        <p class="eyebrow">{section.eyebrow}</p>
        <h2>{section.title}</h2>
        {section.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>
  ))}

  <section class="section cta-band">
    <div class="container prose-block">
      <p class="eyebrow">{about.closingEyebrow}</p>
      <h2>{about.closingTitle}</h2>
      <p>{about.closingBody}</p>
    </div>
  </section>
</MainLayout>
