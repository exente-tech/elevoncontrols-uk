---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { market } from "../../data/current-market";

const industry = market.industries.items.find((item) => item.slug === "pump-systems");
if (!industry) throw new Error("Missing industry content: pump-systems");
---

<MainLayout title={industry.pageTitle} description={industry.pageDescription}>
  <PageHero eyebrow={industry.heroEyebrow} title={industry.heroTitle} description={industry.heroDescription} />

  <section class="section">
    <div class="container prose-block">
      <p>{industry.intro}</p>
    </div>
  </section>
</MainLayout>
