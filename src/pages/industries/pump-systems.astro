---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<MainLayout
  title="Pump Systems Automation"
  description="PLC programming and automation support for pump stations and pressure boosting systems."
>
  <PageHero
    eyebrow="Industry"
    title="Pump Systems"
    description="Automation engineering for pumping stations, booster systems, and control strategies that protect assets and improve reliability."
  />

  <section class="section">
    <div class="container prose-block">
      <p>
        Pump system automation needs stable logic, good alarm handling, and practical control
        strategies. We support projects involving duty and standby control, pump protection, level
        management, and pressure-based sequencing.
      </p>
    </div>
  </section>
</MainLayout>
