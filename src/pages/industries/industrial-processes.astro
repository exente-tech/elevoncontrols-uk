---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<MainLayout
  title="Industrial Process Automation"
  description="Automation support for industrial process projects that need practical engineering delivery."
>
  <PageHero
    eyebrow="Industry"
    title="Industrial Processes"
    description="Selected industrial process applications where teams need straightforward PLC, HMI, and commissioning support."
  />

  <section class="section">
    <div class="container prose-block">
      <p>
        We work on industrial automation projects that need reliable delivery, clear documentation,
        and engineering support that plugs into the wider project team without adding overhead.
      </p>
    </div>
  </section>
</MainLayout>
