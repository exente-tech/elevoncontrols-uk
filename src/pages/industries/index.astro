---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { market } from "../../data/current-market";

const industries = market.industries;
---

<MainLayout title={industries.overviewTitle} description={industries.overviewDescription}>
  <PageHero eyebrow={industries.heroEyebrow} title={industries.heroTitle} description={industries.heroDescription} />

  <section class="section">
    <div class="container card-grid card-grid-three">
      {industries.items.map((industry) => (
        <a class="info-card" href={industry.href}>
          <h2>{industry.title}</h2>
          <p>{industry.body}</p>
        </a>
      ))}
    </div>
  </section>
</MainLayout>
