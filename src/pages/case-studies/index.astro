---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { market } from "../../data/current-market";

const caseStudiesPage = market.caseStudiesPage;
const caseStudies = market.caseStudies;
---

<MainLayout title={caseStudiesPage.title} description={caseStudiesPage.description}>
  <PageHero eyebrow={caseStudiesPage.heroEyebrow} title={caseStudiesPage.heroTitle} description={caseStudiesPage.heroDescription} />

  <section class="section">
    <div class="container card-grid card-grid-three">
      {caseStudies.map((item) => (
        <article class="info-card">
          <h2>{item.title}</h2>
          <p>{item.summary}</p>
          <p class="result-copy">{item.result}</p>
        </article>
      ))}
    </div>
  </section>
</MainLayout>
