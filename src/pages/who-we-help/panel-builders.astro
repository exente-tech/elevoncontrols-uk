---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<MainLayout
  title="Support for Panel Builders"
  description="External PLC and control system support for panel builders delivering automation projects."
>
  <PageHero
    eyebrow="Who We Help"
    title="Panel Builders"
    description="We act as an external PLC and automation engineering team when projects need extra delivery capacity."
  />

  <section class="section">
    <div class="container prose-block">
      <p>
        We support panel builders with PLC programming, HMI development, control system design, and
        project documentation so your team can deliver complete projects without increasing internal
        headcount.
      </p>
    </div>
  </section>
</MainLayout>
