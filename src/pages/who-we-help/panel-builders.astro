---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { market } from "../../data/current-market";

const audience = market.audiences.items.find((item) => item.slug === "panel-builders");
if (!audience) throw new Error("Missing audience content: panel-builders");
---

<MainLayout title={audience.pageTitle} description={audience.pageDescription}>
  <PageHero eyebrow={audience.heroEyebrow} title={audience.heroTitle} description={audience.heroDescription} />

  <section class="section">
    <div class="container prose-block">
      <p>{audience.intro}</p>
    </div>
  </section>
</MainLayout>
