---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { market } from "../../data/current-market";

const audiences = market.audiences;
---

<MainLayout title={audiences.overviewTitle} description={audiences.overviewDescription}>
  <PageHero eyebrow={audiences.heroEyebrow} title={audiences.heroTitle} description={audiences.heroDescription} />

  <section class="section">
    <div class="container prose-block">
      <p>{audiences.intro}</p>
    </div>
  </section>

  {audiences.sections.map((section) => (
    <section class:list={["section", section.muted && "section-muted"]}>
      <div class="container prose-block">
        <p class="eyebrow">{section.eyebrow}</p>
        <h2>{section.title}</h2>
        {section.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>
  ))}

  <section class="section cta-band">
    <div class="container prose-block">
      <p class="eyebrow">{audiences.closingEyebrow}</p>
      <h2>{audiences.closingTitle}</h2>
      <p>{audiences.closingBody}</p>
    </div>
  </section>
</MainLayout>
