---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<MainLayout
  title="Support for Contractors"
  description="Reliable control system design and PLC programming support for contractors working on pump and water projects."
>
  <PageHero
    eyebrow="Who We Help"
    title="Contractors"
    description="We help contractors deliver dependable pump and water control systems with practical automation support."
  />

  <section class="section">
    <div class="container prose-block">
      <p>
        For contractors delivering pump stations, booster systems, or water infrastructure, we
