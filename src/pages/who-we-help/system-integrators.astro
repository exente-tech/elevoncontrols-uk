---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<MainLayout
  title="Support for System Integrators"
  description="Flexible automation engineering support for system integrators from design through commissioning."
>
  <PageHero
    eyebrow="Who We Help"
    title="System Integrators"
    description="We add engineering capacity for automation projects that need reliable delivery support from design through commissioning."
  />

