---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { market } from "../../data/current-market";

const service = market.services.items.find((item) => item.slug === "hmi-scada");
if (!service) throw new Error("Missing service content: hmi-scada");
---

<MainLayout title={service.pageTitle} description={service.pageDescription}>
  <PageHero eyebrow={service.heroEyebrow} title={service.heroTitle} description={service.heroDescription} />

  <section class="section">
    <div class="container prose-block">
      <p>{service.intro}</p>
      {service.features && (
        <ul class="feature-list feature-list-inline">
          {service.features.map((item) => <li>{item}</li>)}
        </ul>
      )}
    </div>
  </section>
</MainLayout>
