---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<MainLayout
  title="HMI & SCADA Development"
  description="Operator interfaces, alarms, monitoring, and visualisation for industrial automation systems."
>
  <PageHero
    eyebrow="Service"
    title="HMI & SCADA Development"
    description="Operator interfaces and monitoring systems that make equipment easier to run, diagnose, and support."
  />

  <section class="section">
    <div class="container prose-block">
      <p>
        Effective HMI and SCADA design improves usability, visibility, and response time when
        issues occur. We create interfaces that operators can understand quickly and use with
        confidence.
      </p>
      <ul class="feature-list feature-list-inline">
        <li>Operator interfaces</li>
        <li>Alarm visibility</li>
        <li>Remote monitoring</li>
        <li>Data visualisation</li>
        <li>Practical layout standards</li>
      </ul>
    </div>
  </section>
</MainLayout>
