---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { market } from "../../data/current-market";

const services = market.services;
---

<MainLayout title={services.overviewTitle} description={services.overviewDescription}>
  <PageHero eyebrow={services.heroEyebrow} title={services.heroTitle} description={services.heroDescription} />

  <section class="section">
    <div class="container card-grid card-grid-two">
      {services.items.map((service) => (
        <a class="info-card info-card-strong" href={service.href}>
          <h2>{service.title}</h2>
          <p>{service.body}</p>
        </a>
      ))}
    </div>
  </section>
</MainLayout>
