---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<MainLayout
  title="Control Panel Design"
  description="Control panel design, schematics, I/O planning, and documentation support."
>
  <PageHero
    eyebrow="Service"
    title="Control Panel Design"
    description="Electrical schematics, I/O lists, architecture planning, and practical documentation that supports delivery."
  />

  <section class="section">
    <div class="container prose-block">
      <p>
        We help panel builders and integrators translate project requirements into practical control
        panel documentation. That includes electrical schematics, architecture planning, I/O lists,
        and support for FAT preparation.
      </p>
      <ul class="feature-list feature-list-inline">
        <li>Electrical schematics</li>
        <li>I/O lists and architecture</li>
        <li>Documentation packs</li>
        <li>Panel builder collaboration</li>
        <li>FAT support</li>
      </ul>
    </div>
  </section>
</MainLayout>
