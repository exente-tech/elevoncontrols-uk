---
import MainLayout from "../../layouts/MainLayout.astro";
import PageHero from "../../components/PageHero.astro";
---

<MainLayout
  title="PLC Programming"
  description="PLC programming support for Siemens, Codesys, and Allen-Bradley systems."
>
  <PageHero
    eyebrow="Service"
    title="PLC Programming"
    description="Programming support for new systems, upgrades, troubleshooting, and control sequence optimisation."
  />

  <section class="section">
    <div class="container prose-block">
      <p>
        We support automation projects with PLC software development that is clear, maintainable,
        and aligned with real operating conditions. Our work covers new systems, retrofit projects,
        and sequence adjustments needed during delivery.
      </p>
      <ul class="feature-list feature-list-inline">
        <li>Siemens</li>
        <li>Codesys</li>
        <li>Allen-Bradley</li>
        <li>New systems and upgrades</li>
        <li>Troubleshooting and optimisation</li>
      </ul>
    </div>
  </section>
</MainLayout>
