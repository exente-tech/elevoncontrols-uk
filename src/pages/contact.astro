---
import ContactForm from "../components/ContactForm.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { market } from "../data/current-market";

const site = market.site;
const contact = market.contact;
---

<MainLayout title={contact.title} description={contact.description}>
  <section class="page-hero">
    <div class="container contact-hero-grid">
      <div>
        <p class="eyebrow">{contact.eyebrow}</p>
        <h1>{contact.heading}</h1>
        <p class="page-hero-copy">{contact.body}</p>
        <div class="contact-details">
          <p><strong>{contact.labels.email}:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
          <p><strong>{contact.labels.phone}:</strong> <a href={`tel:${site.phone.replace(/[^+\d]/g, "")}`}>{site.phone}</a></p>
          <p><strong>{contact.labels.mobile}:</strong> <a href={`tel:${site.mobile.replace(/[^+\d]/g, "")}`}>{site.mobile}</a></p>
          <p><strong>{contact.labels.address}:</strong> {site.address}</p>
        </div>
      </div>

      <ContactForm />
    </div>
  </section>
</MainLayout>
